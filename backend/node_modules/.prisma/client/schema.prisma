generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Staff {
  id             String        @id @default(cuid())
  name           String
  role           String        @default("Stylist")
  phone          String?
  rating         Float         @default(5.0)
  status         String        @default("Active") // Active, On Leave, Inactive
  experience     String? // e.g. "5 Years"
  specialization String? // e.g. "Hair Coloring, Bridal"
  invoices       InvoiceItem[]
  appointments   Appointment[]
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  phone     String?   @unique
  history   Invoice[]
  createdAt DateTime  @default(now())

  // Membership Information
  isMember         Boolean   @default(false)
  membershipId     String?   @unique // Auto-generated ID, e.g., "NAT-M-1209"
  membershipTier   String?   @default("Standard") // e.g., "Standard", "Premium"
  membershipStart  DateTime?
  membershipExpiry DateTime?
}

model Service {
  id           String        @id @default(cuid())
  code         String        @unique
  description  String
  price        Float
  mPrice       Float?
  gender       String? // Male, Female, Unisex
  category     String?
  subcategory  String?
  gst          Float         @default(0.0) // GST Percentage
  items        InvoiceItem[]
  appointments Appointment[]
}

model Product {
  id          String        @id @default(cuid())
  code        String        @unique
  description String
  price       Float
  mPrice      Float?
  category    String?
  gst         Float         @default(0.0) // GST Percentage
  items       InvoiceItem[]
}

model Package {
  id          String        @id @default(cuid())
  code        String        @unique
  description String
  price       Float
  mPrice      Float?
  gst         Float         @default(0.0) // GST Percentage
  items       InvoiceItem[]
}

model MembershipPlan {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String // e.g., "Annual Gold"
  price        Float
  durationDays Int // e.g., 365
  gst          Float         @default(0.0) // GST Percentage
  items        InvoiceItem[]
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceId     String        @unique // e.g., "6870"
  date          DateTime      @default(now())
  customer      Customer?     @relation(fields: [customerId], references: [id])
  customerId    String?
  totalGross    Float
  totalDiscount Float         @default(0)
  totalTax      Float         @default(0)
  totalNet      Float
  payments      Payment[]
  items         InvoiceItem[]
}

model InvoiceItem {
  id               String          @id @default(cuid())
  invoice          Invoice         @relation(fields: [invoiceId], references: [id])
  invoiceId        String
  service          Service?        @relation(fields: [serviceId], references: [id])
  serviceId        String?
  product          Product?        @relation(fields: [productId], references: [id])
  productId        String?
  package          Package?        @relation(fields: [packageId], references: [id])
  packageId        String?
  membershipPlan   MembershipPlan? @relation(fields: [membershipPlanId], references: [id])
  membershipPlanId String?
  staff            Staff           @relation(fields: [staffId], references: [id])
  staffId          String
  quantity         Int             @default(1)
  price            Float
  gst              Float           @default(0.0)
  taxAmount        Float           @default(0.0)
  total            Float
}

model Payment {
  id        String  @id @default(cuid())
  invoice   Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId String
  method    String // Cash, Card, GPay, Paytm, PhonePe
  amount    Float
}

model Appointment {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String?
  staffId       String?
  staff         Staff?   @relation(fields: [staffId], references: [id])
  serviceId     String?
  service       Service? @relation(fields: [serviceId], references: [id])
  date          DateTime
  time          String
  status        String   @default("Scheduled") // Scheduled, Completed, Cancelled, No Show
  notes         String?
  createdAt     DateTime @default(now())
}

model DailyClosing {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  expectedCash Float
  actualCash   Float
  difference   Float
  totalUPI     Float
  totalCard    Float
  status       String   @default("Completed")
  notes        String?
  closedAt     DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique // e.g., 'store_profile', 'billing_taxes', 'notifications', 'appearance'
  value String // JSON stringified data
}
